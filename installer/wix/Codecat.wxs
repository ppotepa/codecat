<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Codecat"
    Manufacturer="Pawel Potepa"
    Version="$(var.ProductVersion)"
    UpgradeCode="{AD14DCB2-C1DD-4616-A7AB-ACB1939D2504}"
    Scope="perMachine">

    <SummaryInformation Description="Codecat Windows Installer" Manufacturer="Pawel Potepa" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Codecat is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="Codecat" Level="1">
      <ComponentGroupRef Id="CodecatComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Codecat" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="CodecatComponents" Directory="INSTALLFOLDER">
      <Component Id="CodecatExecutable" Guid="*">
        <File Id="CodecatExe" Source="$(var.PublishDir)\Codecat.exe" KeyPath="yes" />
        <Environment
          Id="AddCodecatToPath"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="yes" />
      </Component>
      <Component Id="CodecatReadme" Guid="*">
        <File Id="ReadmeFile" Source="$(var.RepoRoot)\README.md" KeyPath="yes" />
      </Component>
      <Component Id="CodecatLicense" Guid="*">
        <File Id="LicenseFile" Source="$(var.RepoRoot)\LICENSE" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
